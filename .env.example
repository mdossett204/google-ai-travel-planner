# Server-side API keys used by the Vercel functions in /api.
# These are not exposed to the browser.

# Required: used by the recommendations route and the first two itinerary stages.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Required: used by the final itinerary verification/formatting stage.
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"

# Required: used to verify hotels, restaurants, and attractions by place search.
TOMTOM_SEARCH_API_KEY="YOUR_TOMTOM_SEARCH_API_KEY"

# Optional: only needed if you switch the verification model or test OpenAI routing.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Optional: controls the default provider in api/utils/llmRouter.ts when a request
# does not explicitly set one. Supported values: gemini, anthropic, openai.
DEFAULT_LLM_PROVIDER="gemini"

# Optional: enables verbose server-side logging for LLM/tool routing and TomTom search.
DEBUG_LLM_ROUTER="false"
