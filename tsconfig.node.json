{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "scripts/**/*.ts",
    "tools/**/*.ts",
    "utils/**/*.ts",
    "vite.config.ts"
  ]
}
